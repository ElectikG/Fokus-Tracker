<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fokus Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #0a0a0f;
      --surface:      #13131a;
      --border:       #1f1f2e;
      --accent:       #7c6cfc;
      --accent-glow:  rgba(124,108,252,0.35);
      --text:         #e8e8f0;
      --muted:        #6b6b80;
      --green:        #4ade80;
      --orange:       #fb923c;
      --red:          #f87171;
      --radius:       16px;
    }

    body {
      font-family: 'Syne', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 1.5rem;
      background-image:
        radial-gradient(ellipse 60% 40% at 20% 10%, rgba(124,108,252,0.12) 0%, transparent 60%),
        radial-gradient(ellipse 50% 30% at 80% 90%, rgba(252,108,143,0.08) 0%, transparent 55%);
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 2.5rem 2rem;
      width: 100%; max-width: 420px;
      box-shadow: 0 24px 64px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
    }

    /* ── Header ── */
    .header { display: flex; align-items: center; gap: 10px; margin-bottom: 2rem; }
    .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); box-shadow: 0 0 10px var(--accent);
      transition: background 0.3s, box-shadow 0.3s;
    }
    .dot.running { background: var(--green);  box-shadow: 0 0 10px var(--green);  animation: pulse 1.4s infinite; }
    .dot.paused  { background: var(--orange); box-shadow: 0 0 10px var(--orange); }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }
    h2 { font-size: 1rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }

    /* ── Topic Input ── */
    .input-wrap { position: relative; margin-bottom: 1.25rem; }
    .input-wrap label {
      display: block; font-size: 0.7rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 6px;
    }
    .input-wrap input {
      width: 100%; padding: 12px 16px;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; color: var(--text);
      font-family: 'Syne', sans-serif; font-size: 0.95rem;
      outline: none; transition: border-color 0.2s, box-shadow 0.2s, opacity 0.2s;
    }
    .input-wrap input::placeholder { color: var(--muted); }
    .input-wrap input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(124,108,252,0.15); }
    .input-wrap input:disabled { opacity: 0.45; cursor: not-allowed; }

    /* ── Dauer-Picker ── */
    .duration-wrap { margin-bottom: 2rem; }
    .duration-wrap label {
      display: block; font-size: 0.7rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 8px;
    }
    .duration-row { display: flex; gap: 8px; align-items: center; }
    .preset-btns { display: flex; gap: 6px; flex-wrap: wrap; }
    .preset {
      padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 600;
      background: var(--bg); border: 1px solid var(--border); color: var(--muted);
      cursor: pointer; transition: all 0.15s; font-family: 'Syne', sans-serif;
    }
    .preset:hover { border-color: var(--accent); color: var(--accent); }
    .preset.active { background: rgba(124,108,252,0.15); border-color: var(--accent); color: var(--accent); }
    .preset:disabled { opacity: 0.4; cursor: not-allowed; }
    .duration-custom-wrap { position: relative; flex: 1; min-width: 80px; }
    .duration-custom-wrap input[type="number"] {
      width: 100%; padding: 6px 36px 6px 12px;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 8px; color: var(--text);
      font-family: 'DM Mono', monospace; font-size: 0.85rem;
      outline: none; transition: border-color 0.2s, box-shadow 0.2s, opacity 0.2s;
      -moz-appearance: textfield;
    }
    .duration-custom-wrap input[type="number"]::-webkit-outer-spin-button,
    .duration-custom-wrap input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; }
    .duration-custom-wrap input[type="number"]:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(124,108,252,0.15); }
    .duration-custom-wrap input[type="number"]:disabled { opacity: 0.4; cursor: not-allowed; }
    .duration-unit {
      position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
      font-size: 0.7rem; color: var(--muted); pointer-events: none;
    }

    /* ── Timer Ring ── */
    .timer-wrap {
      position: relative; display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem; width: 200px; height: 200px;
    }
    .timer-svg { position: absolute; top: 0; left: 0; transform: rotate(-90deg); }
    .ring-bg { fill: none; stroke: var(--border); stroke-width: 4; }
    .ring-progress {
      fill: none; stroke-width: 4; stroke: var(--accent); stroke-linecap: round;
      stroke-dasharray: 565.48; stroke-dashoffset: 0;
      transition: stroke-dashoffset 0.9s linear, stroke 0.5s;
      filter: drop-shadow(0 0 6px var(--accent));
    }
    .ring-progress.warning { stroke: var(--orange); filter: drop-shadow(0 0 6px var(--orange)); }
    .ring-progress.low     { stroke: var(--red);    filter: drop-shadow(0 0 6px var(--red)); }
    .timer-inner { text-align: center; z-index: 1; }
    .timer-display {
      font-family: 'DM Mono', monospace; font-size: 3.2rem;
      font-weight: 500; letter-spacing: -0.03em; line-height: 1;
    }
    .timer-label {
      font-size: 0.65rem; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--muted); margin-top: 6px;
    }

    /* ── Progress Bar ── */
    .progress-wrap { margin-bottom: 1.75rem; }
    .progress-track { height: 4px; background: var(--border); border-radius: 99px; overflow: hidden; }
    .progress-fill {
      height: 100%; width: 100%; background: var(--accent);
      border-radius: 99px; transition: width 1s linear, background 0.5s;
      box-shadow: 0 0 8px rgba(124,108,252,0.5);
    }
    .progress-fill.warning { background: var(--orange); box-shadow: 0 0 8px rgba(251,146,60,0.5); }
    .progress-fill.low     { background: var(--red);    box-shadow: 0 0 8px rgba(248,113,113,0.5); }

    /* ── Buttons ── */
    .btn-row { display: flex; gap: 10px; }
    .btn {
      flex: 1; padding: 13px;
      border: 1px solid transparent; border-radius: 10px;
      font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 600; letter-spacing: 0.05em;
      cursor: pointer; position: relative; overflow: hidden;
      transition: transform 0.15s, box-shadow 0.2s, background 0.2s, border-color 0.2s, color 0.2s;
    }
    .btn::after { content:''; position:absolute; inset:0; background:white; opacity:0; transition:opacity 0.15s; }
    .btn:active { transform: scale(0.96); }
    .btn:active::after { opacity: 0.06; }
    .btn-start { background: var(--accent); color: #fff; box-shadow: 0 4px 20px var(--accent-glow); }
    .btn-start:hover { background: #9080ff; box-shadow: 0 6px 28px rgba(124,108,252,0.55); transform: translateY(-1px); }
    .btn-pause { background: rgba(251,146,60,0.15); border-color: rgba(251,146,60,0.35); color: var(--orange); }
    .btn-pause:hover { background: rgba(251,146,60,0.25); border-color: var(--orange); transform: translateY(-1px); }
    .btn-reset { background: transparent; border-color: var(--border); color: var(--muted); }
    .btn-reset:hover { border-color: var(--red); color: var(--red); background: rgba(248,113,113,0.08); transform: translateY(-1px); }
    .hidden { display: none !important; }

    /* ── History ── */
    .history { margin-top: 2rem; }
    .history-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .history-header span { font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
    .badge { background: var(--border); color: var(--accent); font-size: 0.7rem; padding: 2px 8px; border-radius: 20px; font-weight: 700; }
    .history-list { display: flex; flex-direction: column; gap: 8px; max-height: 230px; overflow-y: auto; }
    .history-list::-webkit-scrollbar { width: 4px; }
    .history-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    .history-item {
      display: flex; align-items: center; gap: 10px;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 10px 14px; font-size: 0.85rem;
      animation: slideIn 0.3s ease;
    }
    @keyframes slideIn { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:none} }
    .item-topic { font-weight: 600; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .item-meta  { font-size: 0.75rem; color: var(--muted); flex-shrink: 0; }
    .empty { color: var(--muted); font-size: 0.85rem; text-align: center; padding: 1.5rem 0; }

    /* ── Toast ── */
    .toast {
      position: fixed; bottom: 2rem; left: 50%;
      transform: translateX(-50%) translateY(20px);
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.9rem;
      padding: 12px 24px; border-radius: 50px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.3s, transform 0.3s;
      white-space: nowrap; z-index: 999;
    }
    .toast.success { background: var(--green);   color: #0a0a0f; box-shadow: 0 8px 32px rgba(74,222,128,0.4); }
    .toast.info    { background: var(--surface); color: var(--text); border: 1px solid var(--border); box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
    .toast.show    { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ── Modal ── */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
      display: flex; align-items: center; justify-content: center; z-index: 1000;
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    .modal-overlay.show { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
      padding: 2rem; width: 90%; max-width: 320px; text-align: center;
      transform: scale(0.94); transition: transform 0.2s;
      box-shadow: 0 24px 64px rgba(0,0,0,0.6);
    }
    .modal-overlay.show .modal { transform: scale(1); }
    .modal h3 { font-size: 1.1rem; }
    .modal p  { font-size: 0.95rem; color: var(--muted); line-height: 1.6; margin-top: 8px; }
    .modal-btns { display: flex; gap: 10px; margin-top: 1.5rem; }

    /* ── Mobile ── */
    @media (max-width: 480px) {
      .card { padding: 1.75rem 1.25rem; border-radius: 20px; }
      .timer-wrap { width: 170px; height: 170px; }
      .timer-display { font-size: 2.6rem; }
      .preset { padding: 5px 9px; font-size: 0.75rem; }
    }
  </style>
</head>
<body>

<div class="card">

  <!-- Header -->
  <div class="header">
    <div class="dot" id="status-dot"></div>
    <h2>Fokus Session</h2>
  </div>

  <!-- Thema -->
  <div class="input-wrap">
    <label for="topic">Heutiges Thema</label>
    <input type="text" id="topic" placeholder="z.B. Mathematik, Philosophie …">
  </div>

  <!-- Dauer wählen -->
  <div class="duration-wrap">
    <label>Fokus-Dauer</label>
    <div class="duration-row">
      <div class="preset-btns">
        <button class="preset" data-min="15"  onclick="setPreset(15)">15 Min</button>
        <button class="preset active" data-min="30" onclick="setPreset(30)">30 Min</button>
        <button class="preset" data-min="45"  onclick="setPreset(45)">45 Min</button>
        <button class="preset" data-min="60"  onclick="setPreset(60)">60 Min</button>
      </div>
      <div class="duration-custom-wrap">
        <input type="number" id="custom-duration" value="30" min="1" max="180"
               oninput="setCustomDuration(this.value)"
               onkeydown="handleDurationKey(event)">
        <span class="duration-unit">min</span>
      </div>
    </div>
  </div>

  <!-- Timer Ring -->
  <div class="timer-wrap">
    <svg class="timer-svg" width="200" height="200" viewBox="0 0 200 200">
      <circle class="ring-bg" cx="100" cy="100" r="90"/>
      <circle class="ring-progress" id="ring" cx="100" cy="100" r="90"/>
    </svg>
    <div class="timer-inner">
      <div class="timer-display" id="time-display">30:00</div>
      <div class="timer-label"   id="timer-label">bereit</div>
    </div>
  </div>

  <!-- Progress Bar -->
  <div class="progress-wrap">
    <div class="progress-track">
      <div class="progress-fill" id="progress-fill"></div>
    </div>
  </div>

  <!-- Buttons -->
  <div class="btn-row">
    <button class="btn btn-start"        id="start-btn"  onclick="startTimer()">Start</button>
    <button class="btn btn-pause hidden" id="pause-btn"  onclick="pauseTimer()">Pause</button>
    <button class="btn btn-reset"        id="reset-btn"  onclick="confirmReset()">Zurücksetzen</button>
  </div>

  <!-- Verlauf -->
  <div class="history">
    <div class="history-header">
      <span>Verlauf</span>
      <span class="badge" id="count-badge">0</span>
    </div>
    <div class="history-list" id="history-list">
      <p class="empty">Noch keine Sessions — leg los! 🚀</p>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<!-- Modal -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <h3>Timer zurücksetzen?</h3>
    <p>Die aktuelle Session geht verloren und wird nicht gespeichert.</p>
    <div class="modal-btns">
      <button class="btn btn-reset" style="flex:1" onclick="doReset()">Ja, zurücksetzen</button>
      <button class="btn" style="flex:1;background:var(--border);color:var(--text)" onclick="closeModal()">Abbrechen</button>
    </div>
  </div>
</div>

<script>
  /* ── Konfiguration ─────────────────────────────────────────────── */
  const DEFAULT_MINUTES = 30;
  const MAX_HIST        = 50;
  const CIRCUMFERENCE   = 565.48; // 2π × 90

  /* ── State ─────────────────────────────────────────────────────── */
  let totalTime  = DEFAULT_MINUTES * 60;
  let timeLeft   = totalTime;
  let timerId    = null;
  let isRunning  = false;
  let history    = JSON.parse(localStorage.getItem('focusHistory')) || [];

  /* ── XSS-Schutz (FIX #1) ───────────────────────────────────────── */
  function escapeHTML(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  /* ── Dauer-Picker ──────────────────────────────────────────────── */
  function setPreset(min) {
    if (isRunning) return;
    document.getElementById('custom-duration').value = min;
    document.querySelectorAll('.preset').forEach(b =>
      b.classList.toggle('active', +b.dataset.min === min)
    );
    applyDuration(min);
  }

  function setCustomDuration(val) {
    const min = parseInt(val, 10);
    if (isNaN(min) || min < 1) return;
    const capped = Math.min(min, 180);
    document.querySelectorAll('.preset').forEach(b =>
      b.classList.toggle('active', +b.dataset.min === capped)
    );
    applyDuration(capped);
  }

  /* FIX #2 – Enter im Dauer-Feld startet den Timer */
  function handleDurationKey(e) {
    if (e.key === 'Enter') startTimer();
  }

  function applyDuration(min) {
    if (isRunning) return;
    totalTime = min * 60;
    timeLeft  = totalTime;
    updateDisplay();
  }

  function lockDurationControls(locked) {
    document.getElementById('custom-duration').disabled = locked;
    document.querySelectorAll('.preset').forEach(b => b.disabled = locked);
  }

  /* ── Display ───────────────────────────────────────────────────── */
  function urgencyClass() {
    const ratio = timeLeft / totalTime;
    if (ratio <= 1/6) return 'low';      // letzte ~5 Min bei 30 Min
    if (ratio <= 1/3) return 'warning';  // letzte ~10 Min bei 30 Min
    return '';
  }

  function updateDisplay() {
    const m   = Math.floor(timeLeft / 60);
    const s   = timeLeft % 60;
    const str = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;

    document.getElementById('time-display').textContent = str;

    // FIX #5 – Tab-Titel mit Pause-State
    if (isRunning)        document.title = `⏱ ${str} – Fokus`;
    else if (timeLeft < totalTime && timeLeft > 0) document.title = `⏸ ${str} – Pause`;
    else                  document.title = 'Fokus Tracker';

    // Ring
    const offset = CIRCUMFERENCE * (1 - timeLeft / totalTime);
    const ring   = document.getElementById('ring');
    ring.style.strokeDashoffset = offset;
    ring.className = 'ring-progress ' + urgencyClass();

    // Progress Bar
    const fill = document.getElementById('progress-fill');
    fill.style.width = (timeLeft / totalTime * 100) + '%';
    fill.className = 'progress-fill ' + urgencyClass();

    // Label
    const lbl = document.getElementById('timer-label');
    lbl.textContent = isRunning
      ? `${Math.ceil(timeLeft / 60)} Min verbleibend`
      : (timeLeft === totalTime ? 'bereit' : 'pausiert');
  }

  /* ── Audio ─────────────────────────────────────────────────────── */
  function playCompletionSound() {
    try {
      const ctx   = new (window.AudioContext || window.webkitAudioContext)();
      const notes = [523.25, 659.25, 783.99, 1046.5];
      notes.forEach((freq, i) => {
        const osc  = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine'; osc.frequency.value = freq;
        const t = ctx.currentTime + i * 0.18;
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(0.28, t + 0.05);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.55);
        osc.start(t); osc.stop(t + 0.6);
      });
    } catch(e) { /* Safari silent fallback */ }
  }

  /* ── Timer Controls ────────────────────────────────────────────── */
  function startTimer() {
    if (isRunning) return;

    // Dauer aus Feld lesen, falls noch nicht gesetzt
    const customVal = parseInt(document.getElementById('custom-duration').value, 10);
    if (!isNaN(customVal) && customVal >= 1 && timeLeft === totalTime) {
      applyDuration(Math.min(customVal, 180));
    }

    isRunning = true;
    lockDurationControls(true);
    document.getElementById('topic').disabled = true;
    document.getElementById('start-btn').classList.add('hidden');
    document.getElementById('pause-btn').classList.remove('hidden');
    document.getElementById('status-dot').className = 'dot running';

    const topic = document.getElementById('topic').value.trim() || 'Unbenannt';

    timerId = setInterval(() => {
      timeLeft--;
      updateDisplay();
      if (timeLeft <= 0) {
        clearInterval(timerId); timerId = null; isRunning = false;
        saveSession(topic);
        playCompletionSound();
        showToast('🎉 Session geschafft!', 'success');
        doReset(true);
      }
    }, 1000);
  }

  function pauseTimer() {
    if (!isRunning) return;
    clearInterval(timerId); timerId = null; isRunning = false;
    document.getElementById('pause-btn').classList.add('hidden');
    document.getElementById('start-btn').classList.remove('hidden');
    document.getElementById('start-btn').textContent = 'Weiter';
    document.getElementById('status-dot').className = 'dot paused';
    updateDisplay();
  }

  /* FIX #3 – Modal statt confirm() */
  function confirmReset() {
    if (!isRunning && timeLeft === totalTime) { doReset(); return; }
    document.getElementById('modal-overlay').classList.add('show');
  }
  function closeModal() {
    document.getElementById('modal-overlay').classList.remove('show');
  }

  function doReset(silent = false) {
    closeModal();
    clearInterval(timerId); timerId = null; isRunning = false;
    timeLeft = totalTime;
    lockDurationControls(false);
    document.getElementById('topic').disabled = false;
    document.getElementById('start-btn').textContent = 'Start';
    document.getElementById('start-btn').classList.remove('hidden');
    document.getElementById('pause-btn').classList.add('hidden');
    document.getElementById('status-dot').className = 'dot';
    document.title = 'Fokus Tracker';
    updateDisplay();
  }

  /* ── History ───────────────────────────────────────────────────── */
  function saveSession(topic) {
    const date     = new Date().toLocaleDateString('de-DE');
    const duration = Math.round(totalTime / 60);
    history.unshift({ date, topic, duration });
    if (history.length > MAX_HIST) history = history.slice(0, MAX_HIST);
    localStorage.setItem('focusHistory', JSON.stringify(history));
    renderHistory();
  }

  function renderHistory() {
    const list = document.getElementById('history-list');
    document.getElementById('count-badge').textContent = history.length;
    if (!history.length) {
      list.innerHTML = '<p class="empty">Noch keine Sessions — leg los! 🚀</p>';
      return;
    }
    // FIX #1 – XSS-Schutz beim Rendern
    list.innerHTML = history.map(h => `
      <div class="history-item">
        <span>✅</span>
        <span class="item-topic">${escapeHTML(h.topic)}</span>
        <span class="item-meta">${escapeHTML(h.date)} · ${h.duration ?? 30} Min</span>
      </div>`).join('');
  }

  /* ── Toast ─────────────────────────────────────────────────────── */
  function showToast(msg, type = 'info') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className   = `toast ${type}`;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 4000);
  }

  /* ── Keyboard: Enter im Topic-Feld startet Timer (FIX #2) ──────── */
  document.getElementById('topic').addEventListener('keydown', e => {
    if (e.key === 'Enter') startTimer();
  });

  /* ── Escape schließt Modal ──────────────────────────────────────── */
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeModal();
  });

  /* ── Init ──────────────────────────────────────────────────────── */
  updateDisplay();
  renderHistory();
</script>
</body>
</html>
